<?xml version="1.0" encoding="utf-8"?>
<!--
    Auto-backup rules for API 30 and below (API 31+ uses data_extraction_rules.xml).

    android:allowBackup="false" in AndroidManifest disables cloud backup entirely,
    so this file is effectively inactive for the intended release posture.
    It is kept as a safety net in case allowBackup is ever re-enabled, and because
    some API 30 devices may still consult it during restore.

    Cache directories are excluded by the system automatically.
    External app files are covered by domain="external".
-->
<full-backup-content>
    <exclude domain="database"   path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="file"       path="." />
    <exclude domain="root"       path="." />
    <exclude domain="external"   path="." />
</full-backup-content>